PORT=4242
NODE_ENV=development

# Primary news source — https://newsapi.org (free: 100 req/day, dev use only)
NEWSAPI_KEY=your_newsapi_key_here

# Secondary news source — https://gnews.io (free: 100 req/day)
GNEWS_KEY=your_gnews_key_here

# Optional Apify scraping layer — set to false to disable entirely
APIFY_ENABLED=false
APIFY_TOKEN=
APIFY_ACTOR_ID=apify/web-scraper

# Cache TTL in minutes (matches client-side TTL in newsStore.ts)
CACHE_TTL_MINUTES=30

# CORS — comma-separated list of allowed origins
# For physical device testing: add your Mac's LAN IP, e.g. http://192.168.1.x:8081
ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081
