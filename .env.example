# ─── Ravenscroft — Environment Variables ─────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your keys below
# 3. Never commit .env — it's in .gitignore
#
# Variables prefixed EXPO_PUBLIC_ are bundled into the client binary.
# Do NOT put secrets in EXPO_PUBLIC_ variables in production.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Create a project at https://clerk.com → API Keys
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here


# ─── Supabase ────────────────────────────────────────────────────────────────
# Get your keys at https://supabase.com/dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SECRET_KEY=your_supabase_service_role_key_here


# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs → Credentials
# Select "OAuth 2.0 Client ID" → iOS application type
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here


# ─── Google Books API ─────────────────────────────────────────────────────────
# Get a key at https://console.cloud.google.com → APIs → Books API → Enable
# Without a key, searches are rate-limited to ~1 req/sec and may return empty results
EXPO_PUBLIC_GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here


# ─── Anthropic AI (Claude Assistant) ─────────────────────────────────────────
# Get your key at https://console.anthropic.com → API Keys
# Note: In production, proxy this through a backend to avoid exposing the key
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here


# ─── News Backend ─────────────────────────────────────────────────────────────
# Local dev:      http://localhost:4242
# Physical device: use your Mac's LAN IP, e.g. http://192.168.1.x:4242
# Production:     https://your-deployed-backend.up.railway.app
EXPO_PUBLIC_NEWS_API_BASE_URL=http://localhost:4242


# ─── App Environment ─────────────────────────────────────────────────────────
# Options: development | staging | production
EXPO_PUBLIC_APP_ENV=development
